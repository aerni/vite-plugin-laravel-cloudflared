{
    "name": "@aerni/vite-plugin-laravel-cloudflared",
    "version": "1.0.0",
    "description": "Companion plugin to seamlessly integrate Cloudflared for Laravel with your Vite development server",
    "keywords": [
        "vite",
        "vite-plugin",
        "cloudflare",
        "cloudflared",
        "tunnel"
    ],
    "homepage": "https://github.com/aerni/vite-plugin-laravel-cloudflared",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/aerni/vite-plugin-laravel-cloudflared.git"
    },
    "license": "MIT",
    "author": "Michael Aerni",
    "type": "module",
    "exports": {
        ".": {
            "default": "./dist/index.js"
        }
    },
    "files": [
        "/dist"
    ],
    "scripts": {
        "build": "npm run build-plugin",
        "build-plugin": "rm -rf dist && npm run build-plugin-esm",
        "build-plugin-esm": "esbuild src/index.js --platform=node --format=esm --outfile=dist/index.js",
        "lint": "eslint --ext .js ./src"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.30.1",
        "esbuild": "0.25.6",
        "eslint": "^9.0.0",
        "vite": "^7.0.0"
    },
    "peerDependencies": {
        "vite": "^7.0.0"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "dependencies": {
        "js-yaml": "^4.1.0",
        "picocolors": "^1.0.0"
    }
}
